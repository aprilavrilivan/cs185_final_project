+def _rank_group_advantages(
+    rewards_reshaped: torch.Tensor,
+    eps: float = 1e-6,
+) -> torch.Tensor:
+    if rewards_reshaped.ndim != 2:
+        raise ValueError(f"rank advantages expect [num_groups, group_size], got {tuple(rewards_reshaped.shape)}")
+
+    group_size = int(rewards_reshaped.shape[1])
+    if group_size <= 1:
+        return torch.zeros_like(rewards_reshaped, dtype=torch.float32)
+
+    order = torch.argsort(rewards_reshaped, dim=1)
+    ranks = torch.empty_like(rewards_reshaped, dtype=torch.float32)
+
+    rank_values = torch.arange(
+        group_size,
+        device=rewards_reshaped.device,
+        dtype=torch.float32,
+    ).view(1, group_size).expand(rewards_reshaped.shape[0], group_size)
+
+    ranks.scatter_(1, order, rank_values)
+
+    center = 0.5 * float(group_size - 1)
+    scale = max(center, float(eps))
+    advantages = (ranks - center) / scale
+
+    # If all rewards in a group are exactly tied, do not create an artificial preference.
+    spread = (
+        rewards_reshaped.max(dim=1, keepdim=True).values
+        - rewards_reshaped.min(dim=1, keepdim=True).values
+    )
+    return torch.where(spread > eps, advantages, torch.zeros_like(advantages))
+
